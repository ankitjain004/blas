      "boundElements": null,
      "updated": 1780246814998,
      "link": null,
      "locked": false,
      "text": "until it lands on a trusted root — then the whole chain is trusted. Missing intermediate = 'unable to verify'.",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "middle",
      "baseline": 12,
      "containerId": null,
      "originalText": "until it lands on a trusted root — then the whole chain is trusted. Missing intermediate = 'unable to verify'."
