      "link": null,
      "locked": false,
      "text": "Server sends LEAF + INTERMEDIATE(s).  Device already has the ROOT.  The browser climbs the chain",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "middle",
      "baseline": 12,
      "containerId": null,
      "originalText": "Server sends LEAF + INTERMEDIATE(s).  Device already has the ROOT.  The browser climbs the chain"
    },
    {
      "id": "cf9f9793c2d406229395",
      "type": "text",
      "x": 70,
      "y": 394,
      "width": 792,
      "height": 16.200000000000003,
      "angle": 0,
      "strokeColor": "#7048e8",
      "backgroundColor": "transparent",
